# Supabase Edge Function environment variables
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FCM_SERVER_KEY=

# Calendar push reminders (set in Supabase Dashboard → Edge Functions → Secrets)
APP_URL=https://pulse-one-umber.vercel.app
CRON_SECRET=

# Firebase service account credentials for FCM HTTP v1 delivery.
# Use either FIREBASE_SERVICE_ACCOUNT_JSON or the individual fields below.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# If you are also using VAPID/Web Push on the backend, optionally add:
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
